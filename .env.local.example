# ============================================================================
# Jolchap (জলছাপ) — Environment variables (EXAMPLE / TEMPLATE)
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values, OR edit `.env.local`
# directly (it ships with these keys ready to populate).
#
#   - Variables prefixed NEXT_PUBLIC_ are exposed to the browser. Never put a
#     secret behind a NEXT_PUBLIC_ key.
#   - SUPABASE_SERVICE_ROLE_KEY is SERVER-ONLY and must be kept secret.
#   - The site runs fully WITHOUT Supabase — it falls back to bundled offline
#     content. Add the Supabase keys when you want a live database + admin.
#
# Step-by-step instructions for finding each value are in SETUP-GUIDE.md.
# ============================================================================


# ── Supabase ────────────────────────────────────────────────────────────────
# Your project's REST/Realtime URL. Supabase Dashboard → Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe for the browser). Dashboard → Settings → API → Project API keys → anon public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, bypasses row-level security. KEEP SECRET, never expose to the browser. Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Name of the public Storage bucket that holds uploaded WebP imagery. Create it in Storage → New bucket (public). Leave as `media`.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=media

# Admin allowlist — comma-separated emails allowed into /admin. Customers can create
# normal accounts at /account; only these emails reach the admin dashboard. Leave
# EMPTY and any signed-in user counts as admin — set it to your own email once you
# start accepting customer sign-ups, e.g. ADMIN_EMAILS=owner@jolchap.com.bd
ADMIN_EMAILS=


# ── Site ──────────────────────────────────────────────────────────────────--
# Canonical public URL of the deployed site (used for SEO, sitemap, OG tags). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://jolchap.com.bd

# (Optional) Google Search Console verification token — adds the <meta name="google-site-verification">.
# Get it from Search Console → Add property → "HTML tag" method (copy only the content value).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=


# ── Contact & WhatsApp ───────────────────────────────────────────────────────
# WhatsApp number in international format, no spaces/dashes (the floating button deep-links to wa.me/<number>).
NEXT_PUBLIC_WHATSAPP_NUMBER=+8801700000000

# Public sales/support phone number (shown in the header, footer and contact page).
NEXT_PUBLIC_CONTACT_PHONE=+880 1700 000000

# Public support email address (shown in the footer and contact page).
NEXT_PUBLIC_CONTACT_EMAIL=hello@jolchap.com.bd


# ── Social links ─────────────────────────────────────────────────────────────
# Full profile URLs for the footer/social icons. Replace with your real handles.
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/jolchaplifestyle
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/jolchaplifestyle
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@jolchaplifestyle
NEXT_PUBLIC_SOCIAL_TIKTOK=https://tiktok.com/@jolchaplifestyle
NEXT_PUBLIC_SOCIAL_X=https://x.com/jolchaplifestyle
